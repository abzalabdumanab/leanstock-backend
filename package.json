{
  "name": "leanstock-backend",
  "version": "1.0.0",
  "description": "LeanStock multi-tenant inventory backend with JWT auth, RBAC, catalog and atomic transfers.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "jest --runInBand --forceExit",
    "lint": "eslint src tests --ext .js",
    "smoke:postman": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke-postman.ps1",
    "smoke:rbac": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke-rbac.ps1",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "node scripts/seed.js",
    "studio": "prisma studio",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-handler": "^1.2.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "rate-limiter-flexible": "^5.0.5",
    "redlock": "^5.0.0-beta.2",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
