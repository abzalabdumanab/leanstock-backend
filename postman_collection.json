{
  "info": {
    "name": "LeanStock Production API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1"
    },
    {
      "key": "healthUrl",
      "value": "http://localhost:3000/health"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "verificationToken",
      "value": ""
    },
    {
      "key": "resetToken",
      "value": ""
    },
    {
      "key": "productId",
      "value": ""
    },
    {
      "key": "variantId",
      "value": ""
    },
    {
      "key": "sourceId",
      "value": ""
    },
    {
      "key": "destinationId",
      "value": ""
    },
    {
      "key": "transferId",
      "value": ""
    },
    {
      "key": "supplierId",
      "value": ""
    },
    {
      "key": "tenantId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health - Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{healthUrl}}"
      }
    },
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenantName\": \"Defense Shop {{$timestamp}}\",\n  \"email\": \"owner{{$timestamp}}@arzan.kz\",\n  \"password\": \"SecurePass99!!!\",\n  \"role\": \"TENANT_ADMIN\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('registered', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "if (json.tokens) { pm.collectionVariables.set('accessToken', json.tokens.accessToken); pm.collectionVariables.set('refreshToken', json.tokens.refreshToken); }",
              "if (json.user) { pm.collectionVariables.set('tenantId', json.user.tenantId); }",
              "if (json.verificationToken) { pm.collectionVariables.set('verificationToken', json.verificationToken); }"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Verify Email",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/verify-email",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{verificationToken}}\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@arzan.kz\",\n  \"password\": \"Password123!\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) { const json = pm.response.json(); pm.collectionVariables.set('accessToken', json.tokens.accessToken); pm.collectionVariables.set('refreshToken', json.tokens.refreshToken); pm.collectionVariables.set('tenantId', json.user.tenantId); }"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Refresh",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/refresh",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) { const json = pm.response.json(); pm.collectionVariables.set('accessToken', json.accessToken); pm.collectionVariables.set('refreshToken', json.refreshToken); }"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/logout",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        }
      }
    },
    {
      "name": "Auth - Password Reset Request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/password-reset/request",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@arzan.kz\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) { const json = pm.response.json(); if (json.resetToken) pm.collectionVariables.set('resetToken', json.resetToken); }"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Password Reset Confirm",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/password-reset/confirm",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"NewSecurePass99!!!\"\n}"
        }
      }
    },
    {
      "name": "Products - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/products?limit=20"
      }
    },
    {
      "name": "Products - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/products",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Urban Classic Sneakers {{$timestamp}}\",\n  \"description\": \"Leather city sneakers\",\n  \"category\": \"Footwear\",\n  \"baseUnit\": \"pcs\",\n  \"variants\": [\n    {\n      \"sku\": \"SHOE-DEF-{{$timestamp}}\",\n      \"size\": \"42\",\n      \"color\": \"Black\",\n      \"costPrice\": 2500,\n      \"retailPrice\": 5990,\n      \"liquidationPrice\": 1500,\n      \"reorderPoint\": 10\n    }\n  ]\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) { const json = pm.response.json(); pm.collectionVariables.set('productId', json.id); pm.collectionVariables.set('variantId', json.variants[0].id); }"
            ]
          }
        }
      ]
    },
    {
      "name": "Products - Get By Id",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/products/{{productId}}"
      }
    },
    {
      "name": "Warehouses - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/warehouses"
      }
    },
    {
      "name": "Warehouses - Create Source",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/warehouses",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Main Warehouse {{$timestamp}}\",\n  \"address\": \"Almaty, Zhandosov 55\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) pm.collectionVariables.set('sourceId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Warehouses - Create Destination",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/warehouses",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Second Warehouse {{$timestamp}}\",\n  \"address\": \"Astana, Mangilik El 1\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) pm.collectionVariables.set('destinationId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Stock - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/stock"
      }
    },
    {
      "name": "Stock - Create Or Set",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/stock",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"variantId\": \"{{variantId}}\",\n  \"warehouseId\": \"{{sourceId}}\",\n  \"quantity\": 20\n}"
        }
      }
    },
    {
      "name": "Stock - Reserve",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/stock/reserve",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"variantId\": \"{{variantId}}\",\n  \"warehouseId\": \"{{sourceId}}\",\n  \"quantity\": 2,\n  \"ttlSeconds\": 900\n}"
        }
      }
    },
    {
      "name": "Transfers - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/transfers"
      }
    },
    {
      "name": "Transfers - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/transfers",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sourceId\": \"{{sourceId}}\",\n  \"destinationId\": \"{{destinationId}}\",\n  \"note\": \"Defense transfer\",\n  \"items\": [\n    {\n      \"variantId\": \"{{variantId}}\",\n      \"quantity\": 5\n    }\n  ]\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) pm.collectionVariables.set('transferId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Transfers - Confirm",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/transfers/{{transferId}}/confirm"
      }
    },
    {
      "name": "Transfers - Reject",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/transfers/{{transferId}}/reject"
      }
    },
    {
      "name": "Adjustments - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/adjustments"
      }
    },
    {
      "name": "Adjustments - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/adjustments",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"warehouseId\": \"{{sourceId}}\",\n  \"reason\": \"COUNT_CORRECTION\",\n  \"note\": \"Physical count correction\",\n  \"items\": [\n    {\n      \"variantId\": \"{{variantId}}\",\n      \"delta\": -1\n    }\n  ]\n}"
        }
      }
    },
