          }
        ],
        "url": "{{baseUrl}}/suppliers",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Almaty Wholesale {{$timestamp}}\",\n  \"email\": \"sales@example.kz\",\n  \"phone\": \"+77010000000\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) pm.collectionVariables.set('supplierId', pm.response.json().id);"
