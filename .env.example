NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://leanstock:leanstock@localhost:5432/leanstock_dev?schema=public
TEST_DATABASE_URL=postgresql://leanstock:leanstock@localhost:5432/leanstock_test?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
APP_BASE_URL=http://localhost:3000
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=replace-with-real-provider-secret
SMTP_FROM=LeanStock <noreply@leanstock.kz>
# Set true in production/Cloud Run so queued registration verification emails are sent automatically.
EMAIL_WORKER_ENABLED=false
DEAD_STOCK_AFTER_DAYS=30
DEAD_STOCK_DECAY_PERCENT=10
DEAD_STOCK_DECAY_INTERVAL_DAYS=3
DEAD_STOCK_CRON=0 2 * * *
LOW_STOCK_CRON=*/30 * * * *
