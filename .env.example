NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://leanstock:leanstock@localhost:5432/leanstock_dev?schema=public
DIRECT_URL=postgresql://leanstock:leanstock@localhost:5432/leanstock_dev?schema=public
TEST_DATABASE_URL=postgresql://leanstock:leanstock@localhost:5432/leanstock_test?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:8080
APP_BASE_URL=http://localhost:3000
# Reliable local email option: use Gmail SMTP with a Gmail App Password.
# Enable 2-Step Verification in Google Account, then create an App Password for Mail.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=replace-with-16-character-gmail-app-password
SMTP_FROM=LeanStock <your-gmail-address@gmail.com>
EMAIL_WORKER_ENABLED=true
DEAD_STOCK_AFTER_DAYS=30
DEAD_STOCK_DECAY_PERCENT=10
DEAD_STOCK_DECAY_INTERVAL_DAYS=3
DEAD_STOCK_CRON=0 2 * * *
LOW_STOCK_CRON=*/30 * * * *
